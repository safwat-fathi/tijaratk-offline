generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AvailabilityRequest {
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
  deleted_at   DateTime? @db.Timestamp(6)
  tenant_id    Int
  id           Int       @id(map: "PK_availability_requests_id") @default(autoincrement())
  product_id   Int
  visitor_key  String    @db.VarChar(64)
  request_date DateTime  @db.Date
  product      Product   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_availability_requests_product")
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_availability_requests_tenant")

  @@unique([tenant_id, product_id, visitor_key, request_date], map: "UQ_availability_requests_tenant_product_visitor_date")
  @@index([product_id], map: "IDX_availability_requests_product_id")
  @@index([request_date], map: "IDX_availability_requests_request_date")
  @@index([tenant_id, created_at(sort: Desc)], map: "IDX_availability_requests_tenant_created_at")
  @@index([tenant_id, product_id, request_date], map: "IDX_availability_requests_tenant_product_request_date")
  @@index([visitor_key], map: "IDX_availability_requests_visitor_key")
  @@map("availability_requests")
}

model CatalogItem {
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  id         Int       @id(map: "PK_dd1c29828c10a599d894b9b6535") @default(autoincrement())
  name       String    @db.VarChar
  image_url  String?
  category   String    @db.VarChar
  is_active  Boolean   @default(true)

  @@map("catalog_items")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Customer {
  created_at            DateTime  @default(now()) @db.Timestamp(6)
  updated_at            DateTime  @default(now()) @db.Timestamp(6)
  deleted_at            DateTime? @db.Timestamp(6)
  tenant_id             Int
  id                    Int       @id(map: "PK_133ec679a801fab5e070f73d3ea") @default(autoincrement())
  phone                 String    @db.VarChar
  name                  String?   @db.VarChar
  code                  Int
  merchant_label        String?   @db.VarChar
  address               String?
  notes                 String?
  first_order_at        DateTime? @db.Timestamp(6)
  last_order_at         DateTime? @db.Timestamp(6)
  order_count           Int       @default(0)
  completed_order_count Int       @default(0)
  tenant                Tenant    @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_97913f35ac2e435a4463fb50a01")
  orders                Order[]

  @@unique([tenant_id, code], map: "UQ_31e385cc0f0f40cc6a0149b9806")
  @@unique([tenant_id, phone], map: "UQ_d9ef0802e47c0384f5831b59733")
  @@index([tenant_id], map: "IDX_97913f35ac2e435a4463fb50a0")
  @@map("customers")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DayClosure {
  id                    Int       @id(map: "PK_day_closures_id") @default(autoincrement())
  tenant_id             Int
  closure_date          DateTime  @db.Date
  orders_count          Int       @default(0)
  cancelled_count       Int       @default(0)
  completed_sales_total Decimal   @default(0) @db.Decimal(10, 2)
  closed_at             DateTime  @default(now()) @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamp(6)
  updated_at            DateTime  @default(now()) @db.Timestamp(6)
  deleted_at            DateTime? @db.Timestamp(6)
  tenant                Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_day_closures_tenant")

  @@unique([tenant_id, closure_date], map: "UQ_day_closures_tenant_date")
  @@index([tenant_id], map: "IDX_day_closures_tenant_id")
  @@map("day_closures")
}

model OrderItem {
  id                             Int                       @id(map: "PK_005269d8574e6fac0493715c308") @default(autoincrement())
  order_id                       Int
  product_id                     Int?
  name_snapshot                  String                    @db.VarChar
  quantity                       String
  unit_price                     Decimal?                  @db.Decimal(10, 2)
  total_price                    Decimal?                  @db.Decimal(10, 2)
  notes                          String?
  replaced_by_product_id         Int?
  pending_replacement_product_id Int?
  replacement_decision_status    ReplacementDecisionStatus @default(none) @map("replacement_decision_status")
  replacement_decision_reason    String?
  replacement_decided_at         DateTime?                 @db.Timestamptz(6)
  selection_mode                 OrderItemSelectionMode?   @map("selection_mode")
  selection_quantity             Decimal?                  @db.Decimal(10, 3)
  selection_grams                Int?
  selection_amount_egp           Decimal?                  @db.Decimal(10, 2)
  unit_option_id                 String?                   @db.VarChar(64)

  order                       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_145532db85752b29c57d2b7b1f1")
  product                     Product? @relation("order_items_product_idToproducts", fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_9263386c35b6b242540f9493b00")
  replaced_by_product         Product? @relation("order_items_replaced_by_product_idToproducts", fields: [replaced_by_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_bd6d79fc38399711f5407ea118d")
  pending_replacement_product Product? @relation("order_items_pending_replacement_product_idToproducts", fields: [pending_replacement_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_order_items_pending_replacement_product")

  @@index([pending_replacement_product_id], map: "IDX_order_items_pending_replacement_product")
  @@map("order_items")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Order {
  created_at                DateTime    @default(now()) @db.Timestamp(6)
  updated_at                DateTime    @default(now()) @db.Timestamp(6)
  deleted_at                DateTime?   @db.Timestamp(6)
  tenant_id                 Int
  id                        Int         @id(map: "PK_710e2d4957aa5878dfe94e4ac2f") @default(autoincrement())
  customer_id               Int
  public_token              String      @unique(map: "UQ_3bf085262cc6cb52991c77f90bb") @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar
  order_type                OrderType   @map("order_type")
  status                    OrderStatus @default(draft) @map("status")
  pricing_mode              PricingMode @default(auto) @map("pricing_mode")
  subtotal                      Decimal?    @db.Decimal(10, 2)
  delivery_fee                  Decimal     @default(0) @db.Decimal(10, 2)
  delivery_address              String?
  delivery_time_window_snapshot String?     @db.VarChar(64)
  customer_phone                String?     @db.VarChar
  customer_name                 String?     @db.VarChar
  total                     Decimal?    @db.Decimal(10, 2)
  free_text_payload         Json?
  notes                     String?
  customer_rejection_reason String?
  customer_rejected_at      DateTime?   @db.Timestamptz(6)

  order_items OrderItem[]
  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_527dd6efd5f3402f729c6b3e826")
  customer    Customer    @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_772d0ce0473ac2ccfa26060dbe9")

  @@index([tenant_id], map: "IDX_527dd6efd5f3402f729c6b3e82")
  @@map("orders")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductPriceHistory {
  id             Int       @id(map: "PK_product_price_history_id") @default(autoincrement())
  tenant_id      Int
  product_id     Int
  price          Decimal   @db.Decimal(10, 2)
  effective_from DateTime  @default(now()) @db.Timestamptz(6)
  effective_to   DateTime? @db.Timestamptz(6)
  reason         String?
  product        Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_price_history_product")
  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_price_history_tenant")

  @@index([tenant_id, product_id], map: "IDX_product_price_history_active", where: raw("(effective_to IS NULL)"))
  @@index([tenant_id, product_id, effective_from], map: "IDX_product_price_history_tenant_product_effective_from")
  @@map("product_price_history")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Product {
  created_at    DateTime         @default(now()) @db.Timestamp(6)
  updated_at    DateTime         @default(now()) @db.Timestamp(6)
  deleted_at    DateTime?        @db.Timestamp(6)
  tenant_id     Int
  id            Int              @id(map: "PK_0806c755e0aca124e67c0cf6d7d") @default(autoincrement())
  name          String           @db.VarChar
  image_url     String?
  source        ProductSource    @default(manual) @map("source")
  status        ProductStatus    @default(active) @map("status")
  category      String           @default("أخرى") @db.VarChar(64)
  current_price Decimal?         @db.Decimal(10, 2)
  order_mode    ProductOrderMode @default(quantity) @map("order_mode")
  order_config  Json?
  is_available  Boolean          @default(true)

  availability_requests           AvailabilityRequest[]
  order_items                     OrderItem[]           @relation("order_items_product_idToproducts")
  order_items_replaced            OrderItem[]           @relation("order_items_replaced_by_product_idToproducts")
  order_items_pending_replacement OrderItem[]           @relation("order_items_pending_replacement_product_idToproducts")
  product_price_history           ProductPriceHistory[]
  tenant                          Tenant                @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_9c365ebf78f0e8a6d9e4827ea70")

  @@index([tenant_id], map: "IDX_9c365ebf78f0e8a6d9e4827ea7")
  @@index([tenant_id], map: "IDX_products_tenant_active", where: raw("(status = 'active'::products_status_enum)"))
  @@index([tenant_id, status, category, created_at], map: "IDX_products_tenant_status_category_created_at")
  @@map("products")
}

model TenantProductCategory {
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  tenant_id  Int
  id         Int       @id(map: "PK_tenant_product_categories_id") @default(autoincrement())
  name       String    @db.VarChar(64)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_tenant_product_categories_tenant_id")

  @@unique([tenant_id, name], map: "UQ_tenant_product_categories_tenant_id_name")
  @@index([tenant_id], map: "IDX_tenant_product_categories_tenant_id")
  @@map("tenant_product_categories")
}

model Tenant {
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime       @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?      @db.Timestamp(6)
  id               Int            @id(map: "PK_53be67a04681c66b87ee27c9321") @default(autoincrement())
  name             String         @db.VarChar
  phone            String         @unique(map: "UQ_23d5a62128e1a248126c8453ff0") @db.VarChar
  customer_counter Int            @default(0)
  category         TenantCategory @default(other) @map("category")
  slug             String         @unique(map: "UQ_2310ecc5cb8be427097154b18fc") @db.VarChar
  status           TenantStatus   @default(active) @map("status")
  delivery_fee       Decimal                 @default(0) @db.Decimal(10, 2)
  delivery_available Boolean                 @default(true)
  delivery_starts_at String?                 @db.VarChar(5)
  delivery_ends_at   String?                 @db.VarChar(5)

  availability_requests     AvailabilityRequest[]
  customers                 Customer[]
  day_closures              DayClosure[]
  orders                    Order[]
  product_price_history     ProductPriceHistory[]
  products                  Product[]
  tenant_product_categories TenantProductCategory[]
  users                     User[]

  @@map("tenants")
}

model User {
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  tenant_id  Int
  id         Int       @id(map: "PK_a3ffb1c0c8416b9fc6f907b7433") @default(autoincrement())
  phone      String    @unique(map: "UQ_a000cca60bcf04454e727699490") @db.VarChar
  name       String    @db.VarChar
  role       UserRole  @map("role")
  password   String    @db.VarChar
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_109638590074998bb72a2f2cf08")

  @@index([tenant_id], map: "IDX_109638590074998bb72a2f2cf0")
  @@map("users")
}

enum ReplacementDecisionStatus {
  none
  pending
  approved
  rejected

  @@map("order_items_replacement_decision_status_enum")
}

enum OrderItemSelectionMode {
  quantity
  weight
  price

  @@map("order_items_selection_mode_enum")
}

enum OrderType {
  catalog
  free_text

  @@map("orders_order_type_enum")
}

enum PricingMode {
  auto
  manual

  @@map("orders_pricing_mode_enum")
}

enum OrderStatus {
  draft
  confirmed
  out_for_delivery
  completed
  cancelled
  rejected_by_customer

  @@map("orders_status_enum")
}

enum ProductOrderMode {
  quantity
  weight
  price

  @@map("products_order_mode_enum")
}

enum ProductSource {
  manual
  catalog
  order_note

  @@map("products_source_enum")
}

enum ProductStatus {
  active
  archived

  @@map("products_status_enum")
}

enum TenantCategory {
  grocery
  greengrocer
  butcher
  bakery
  pharmacy
  other

  @@map("tenants_category_enum")
}

enum TenantStatus {
  active
  inactive
  suspended

  @@map("tenants_status_enum")
}

enum UserRole {
  owner
  staff

  @@map("users_role_enum")
}
